project_name: "My Project"
stack_summary: "e.g. Python 3.12 + FastAPI + Postgres, or Next.js 15 + tRPC"
primary_config: "config/settings.yaml"
src_root: "src/"
default_test_command: "pytest -q"
maturity_level: "L1"
date: "{{DATE}}"
